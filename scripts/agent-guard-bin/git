#!/usr/bin/env zsh
set -euo pipefail
umask 077

REAL_GIT="${CODEPILOT_AGENT_REAL_GIT:-/usr/bin/git}"
ROOT="${CODEPILOT_REPO_ROOT:-$(pwd)}"
AUTONOMY="${CODEPILOT_AGENT_PUBLIC_AUTONOMY:-draft}"
EXPECTED_REPO="${CODEPILOT_AGENT_GITHUB_REPO:-codepilotios/codepilot}"
PUBLIC_AUTHOR_NAME="CodePilot"
PUBLIC_AUTHOR_EMAIL="codepilotios""@users.noreply.github.com"

if [[ "${1:-}" == -* ]]; then
  previous_arg=""
  for arg in "$@"; do
    if [[ "$previous_arg" == "-c" || "$previous_arg" == "--config-env" ]] && [[ "$arg" == alias.* ]]; then
      echo "CodePilot agent guard blocked a command-line git alias." >&2
      exit 77
    fi
    case "$arg" in
      -calias.*|-c=alias.*|--config=alias.*|--config-env=alias.*)
        echo "CodePilot agent guard blocked a command-line git alias." >&2
        exit 77
        ;;
      commit|merge|rebase|cherry-pick|reset|checkout|switch|push|send-pack|http-push)
        echo "CodePilot agent guard blocked git $arg with global options." >&2
        echo "Run guarded mutation commands from the target worktree without git global options." >&2
        exit 77
        ;;
    esac
    previous_arg="$arg"
  done
fi

current_branch() {
  "$REAL_GIT" branch --show-current 2>/dev/null || true
}

is_configured_alias() {
  local command_name="${1:-}"
  [[ -n "$command_name" ]] || return 1
  "$REAL_GIT" config --get "alias.$command_name" >/dev/null 2>&1
}

origin_targets_expected_repo() {
  local remote_url github_ssh_user="git"
  remote_url="$("$REAL_GIT" remote get-url origin 2>/dev/null)" || return 1
  case "$remote_url" in
    "https://github.com/$EXPECTED_REPO"|"https://github.com/$EXPECTED_REPO.git"|\
    "${github_ssh_user}@github.com:$EXPECTED_REPO"|"${github_ssh_user}@github.com:$EXPECTED_REPO.git"|\
    "ssh://${github_ssh_user}@github.com/$EXPECTED_REPO"|"ssh://${github_ssh_user}@github.com/$EXPECTED_REPO.git")
      return 0
      ;;
  esac
  return 1
}

audit_push_commits() {
  local source_ref="$1"
  local destination_ref="$2"
  local remote_tracking_ref="refs/remotes/origin/${destination_ref#refs/heads/}"
  local base_ref="refs/remotes/origin/main"
  local range metadata_file messages_file

  if "$REAL_GIT" show-ref --verify --quiet "$remote_tracking_ref"; then
    base_ref="$remote_tracking_ref"
  fi
  "$REAL_GIT" rev-parse --verify --quiet "${source_ref}^{commit}" >/dev/null || return 1
  "$REAL_GIT" rev-parse --verify --quiet "${base_ref}^{commit}" >/dev/null || return 1
  range="${base_ref}..${source_ref}"

  metadata_file="$(mktemp "${TMPDIR:-/tmp}/codepilot-push-metadata.XXXXXX")"
  messages_file="$(mktemp "${TMPDIR:-/tmp}/codepilot-push-messages.XXXXXX")"
  "$REAL_GIT" log --format='%an%x09%ae%x09%cn%x09%ce' "$range" > "$metadata_file"
  "$REAL_GIT" log --format='%B' "$range" > "$messages_file"

  local author_name author_email committer_name committer_email
  while IFS=$'\t' read -r author_name author_email committer_name committer_email; do
    if [[ "$author_name" != "$PUBLIC_AUTHOR_NAME" \
      || "$author_email" != "$PUBLIC_AUTHOR_EMAIL" \
      || "$committer_name" != "$PUBLIC_AUTHOR_NAME" \
      || "$committer_email" != "$PUBLIC_AUTHOR_EMAIL" ]]; then
      rm -f "$metadata_file" "$messages_file"
      echo "CodePilot agent guard blocked a push with non-public commit identity." >&2
      return 1
    fi
  done < "$metadata_file"

  local audit_status=0
  if [[ -x "$ROOT/scripts/privacy-audit.sh" ]]; then
    (cd "$ROOT" && CODEPILOT_PRIVACY_EXTERNAL_FILE="$messages_file" "$ROOT/scripts/privacy-audit.sh" >/dev/null) || audit_status=$?
  fi
  rm -f "$metadata_file" "$messages_file"
  return "$audit_status"
}

if [[ "${1:-}" != -* ]] && is_configured_alias "${1:-}"; then
  echo "CodePilot agent guard blocked a configured git alias." >&2
  exit 77
fi

case "${1:-}" in
  send-pack|http-push)
    echo "CodePilot agent guard blocked direct remote-write plumbing: git $1." >&2
    exit 77
    ;;
  commit|merge|rebase|cherry-pick|reset)
    branch="$(current_branch)"
    if [[ "$branch" == "main" || "$branch" == "master" ]]; then
      echo "CodePilot agent guard blocked git $1 on protected branch '$branch'." >&2
      exit 77
    fi
    ;;
  checkout|switch)
    for arg in "$@"; do
      case "$arg" in
        main|master|origin/main|origin/master)
          echo "CodePilot agent guard blocked switching to protected branch '$arg'." >&2
          exit 77
          ;;
      esac
    done
    ;;
esac

if [[ "${1:-}" == "push" ]]; then
  if [[ "$AUTONOMY" == "launch" ]]; then
    push_args=("${@:2}")
    remote_seen=0
    allowed_remote=0
    refspec_count=0
    reject_push=0
    push_sources=()
    push_destinations=()

    for arg in "${push_args[@]}"; do
      case "$arg" in
        --all|--mirror|--tags|--follow-tags|--delete|-d|--prune)
          reject_push=1
          ;;
        -*)
          ;;
        *)
          if (( remote_seen == 0 )); then
            remote_seen=1
            [[ "$arg" == "origin" ]] && allowed_remote=1
            continue
          fi

          refspec_count=$((refspec_count + 1))
          refspec="${arg#+}"
          if [[ "$refspec" != *:* ]]; then
            reject_push=1
            continue
          fi
          destination="${refspec##*:}"
          case "$destination" in
            refs/heads/agent/*)
              push_sources+=("${refspec%%:*}")
              push_destinations+=("$destination")
              ;;
            *)
              reject_push=1
              ;;
          esac
          ;;
      esac
    done

    if (( remote_seen == 1 && allowed_remote == 1 && refspec_count > 0 && reject_push == 0 )) && origin_targets_expected_repo; then
      if [[ -x "$ROOT/scripts/privacy-audit.sh" ]]; then
        (cd "$ROOT" && "$ROOT/scripts/privacy-audit.sh" >/dev/null)
      fi
      for (( index = 1; index <= ${#push_sources}; index++ )); do
        audit_push_commits "${push_sources[$index]}" "${push_destinations[$index]}" || exit $?
      done
      exec "$REAL_GIT" "$@"
    fi
  fi

  echo "CodePilot agent guard blocked git push." >&2
  echo "Only launch-autonomy pushes to agent/* branches are allowed." >&2
  exit 77
fi

exec "$REAL_GIT" "$@"
