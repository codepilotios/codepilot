#!/usr/bin/env zsh
set -euo pipefail

REAL_GH="${CODEPILOT_AGENT_REAL_GH:-}"
if [[ -z "$REAL_GH" || ! -x "$REAL_GH" ]]; then
  echo "CodePilot agent guard: GitHub CLI is unavailable." >&2
  exit 127
fi

ROOT="${CODEPILOT_REPO_ROOT:-$(pwd)}"
AUTONOMY="${CODEPILOT_AGENT_PUBLIC_AUTONOMY:-draft}"
EXPECTED_REPO="${CODEPILOT_AGENT_GITHUB_REPO:-codepilotios/codepilot}"
top="${1:-}"
sub="${2:-}"

run_privacy_audit() {
  if [[ -x "$ROOT/scripts/privacy-audit.sh" ]]; then
    (cd "$ROOT" && "$ROOT/scripts/privacy-audit.sh" >/dev/null)
  fi
}

has_arg() {
  local expected="$1"
  shift
  for arg in "$@"; do
    [[ "$arg" == "$expected" ]] && return 0
  done
  return 1
}

targets_expected_repo() {
  local repo_target=""
  local expect_repo_value=0
  local arg
  for arg in "$@"; do
    if (( expect_repo_value == 1 )); then
      repo_target="$arg"
      expect_repo_value=0
      continue
    fi
    case "$arg" in
      --repo|-R)
        expect_repo_value=1
        ;;
      --repo=*)
        repo_target="${arg#--repo=}"
        ;;
      -R*)
        repo_target="${arg#-R}"
        ;;
    esac
  done
  (( expect_repo_value == 0 )) && [[ -z "$repo_target" || "$repo_target" == "$EXPECTED_REPO" ]]
}

case "$top:$sub" in
  auth:status|repo:view|repo:list|issue:list|issue:view|issue:status|pr:list|pr:view|pr:status|pr:checks|pr:diff|run:list|run:view|run:watch|workflow:list|workflow:view|release:list|release:view|label:list|search:*)
    exec "$REAL_GH" "$@"
    ;;
  --version:|version:|help:|*:--help)
    exec "$REAL_GH" "$@"
    ;;
esac

if [[ "$AUTONOMY" == "launch" ]]; then
  case "$top:$sub" in
    issue:create)
      if targets_expected_repo "$@"; then
        run_privacy_audit
        exec "$REAL_GH" "$@"
      fi
      ;;
    pr:create)
      if has_arg "--draft" "$@" && targets_expected_repo "$@"; then
        run_privacy_audit
        exec "$REAL_GH" "$@"
      fi
      ;;
  esac
fi

echo "CodePilot agent guard blocked a public GitHub write: gh $*" >&2
echo "Launch autonomy only allows GitHub issues and draft PR creation after privacy audit." >&2
exit 77
