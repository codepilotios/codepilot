#!/usr/bin/env zsh
set -euo pipefail

REAL_GH="${CODEPILOT_AGENT_REAL_GH:-}"
if [[ -z "$REAL_GH" || ! -x "$REAL_GH" ]]; then
  echo "CodePilot agent guard: GitHub CLI is unavailable." >&2
  exit 127
fi

ROOT="${CODEPILOT_REPO_ROOT:-$(pwd)}"
AUTONOMY="${CODEPILOT_AGENT_PUBLIC_AUTONOMY:-draft}"
EXPECTED_REPO="${CODEPILOT_AGENT_GITHUB_REPO:-codepilotios/codepilot}"
top="${1:-}"
sub="${2:-}"

run_privacy_audit() {
  if [[ -x "$ROOT/scripts/privacy-audit.sh" ]]; then
    local outbound_file
    outbound_file="$(mktemp "${TMPDIR:-/tmp}/codepilot-public-content.XXXXXX")"
    trap 'rm -f "$outbound_file" 2>/dev/null || true' EXIT
    printf '%s\n' "$@" > "$outbound_file"
    local audit_status=0
    (cd "$ROOT" && CODEPILOT_PRIVACY_EXTERNAL_FILE="$outbound_file" "$ROOT/scripts/privacy-audit.sh" >/dev/null) || audit_status=$?
    rm -f "$outbound_file"
    trap - EXIT
    return "$audit_status"
  fi
}

body_files_are_tracked() {
  local expect_body_file=0
  local body_file=""
  local arg
  for arg in "$@"; do
    if (( expect_body_file == 1 )); then
      body_file="$arg"
      expect_body_file=0
    elif [[ "$arg" == "--body-file" ]]; then
      expect_body_file=1
      continue
    elif [[ "$arg" == --body-file=* ]]; then
      body_file="${arg#--body-file=}"
    else
      continue
    fi

    [[ -n "$body_file" && "$body_file" != "-" && -f "$ROOT/$body_file" ]] || return 1
    "$REAL_GIT" -C "$ROOT" ls-files --error-unmatch -- "$body_file" >/dev/null 2>&1 || return 1
    body_file=""
  done
  (( expect_body_file == 0 ))
}

has_arg() {
  local expected="$1"
  shift
  for arg in "$@"; do
    [[ "$arg" == "$expected" ]] && return 0
  done
  return 1
}

targets_expected_repo() {
  local repo_target=""
  local expect_repo_value=0
  local arg
  for arg in "$@"; do
    if (( expect_repo_value == 1 )); then
      repo_target="$arg"
      expect_repo_value=0
      continue
    fi
    case "$arg" in
      --repo|-R)
        expect_repo_value=1
        ;;
      --repo=*)
        repo_target="${arg#--repo=}"
        ;;
      -R*)
        repo_target="${arg#-R}"
        ;;
    esac
  done
  (( expect_repo_value == 0 )) && [[ -z "$repo_target" || "$repo_target" == "$EXPECTED_REPO" ]]
}

case "$top:$sub" in
  auth:status|repo:view|repo:list|issue:list|issue:view|issue:status|pr:list|pr:view|pr:status|pr:checks|pr:diff|run:list|run:view|run:watch|workflow:list|workflow:view|release:list|release:view|label:list|search:*)
    exec "$REAL_GH" "$@"
    ;;
  --version:|version:|help:|*:--help)
    exec "$REAL_GH" "$@"
    ;;
esac

if [[ "$AUTONOMY" == "launch" ]]; then
  case "$top:$sub" in
    issue:create)
      if targets_expected_repo "$@" && body_files_are_tracked "$@"; then
        run_privacy_audit "$@" || exit $?
        exec "$REAL_GH" "$@"
      fi
      ;;
    pr:create)
      if has_arg "--draft" "$@" && targets_expected_repo "$@" && body_files_are_tracked "$@"; then
        run_privacy_audit "$@" || exit $?
        exec "$REAL_GH" "$@"
      fi
      ;;
  esac
fi

echo "CodePilot agent guard blocked a public GitHub write." >&2
echo "Launch autonomy only allows GitHub issues and draft PR creation after privacy audit." >&2
exit 77
